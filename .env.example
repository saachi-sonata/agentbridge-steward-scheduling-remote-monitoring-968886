# Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!

# AgentBridge / Workflow Engine Configuration
APPLICATION_BASE_URL=https://your-instance.com
APPLICATION_AUTH_USER=admin
APPLICATION_AUTH_PASSWORD=your_secure_password_here
APPLICATION_ENCRYPTION_KEY=your_encryption_key_here

# API Keys (Required)
OPENAI_API_KEY=your_openai_api_key_here

# GitHub Configuration (for CI/CD)
GITHUB_TOKEN=your_github_personal_access_token_here

# Additional Service Keys
BUSINESS_FUNCTION=your_business_function_here
AUTONOMY_LEVEL=your_autonomy_level_here
AGENTIC_ARCHITECTURE=your_agentic_architecture_here
NODE_ENV=your_node_env_here

# Security Notes:
# - Use strong, unique passwords
# - Rotate API keys regularly  
# - Never share credentials in chat/email
# - Use environment-specific values for dev/staging/prod